"""Parametric quad-mesh LEGO bricks with SubD-ready topology.

The body is built as a 4x4x4 vertex lattice on the box surface. Edge loops
sit at distance `fillet_inset` from each box edge, so when a Subdivision
Surface (Catmull-Clark) is applied at render time, those tight edge loops
RESOLVE INTO ROUNDED FILLETS whose radius equals the inset. This is the
standard hard-surface modeling pattern used by every pro LEGO model on
the asset stores.

Studs are emitted as quad-walled cylinders capped with a single n-gon
(n-gons subdivide cleanly; triangle fans don't).

The underside is modeled as a CONTINUOUS SHELL with the body: the body's
bottom face is removed, an inner cavity (4 walls + a ceiling) drops down
from inside, and a "rim frame" of 12 quads connects the outer bottom
perimeter to the inner bottom perimeter. Because verts are SHARED across
this seam, Catmull-Clark sees one closed surface and produces correctly
filleted edges everywhere -- including the visible bottom rim that
appears when the brick is photographed from below.

Components produced (each as its own polygon group, so the artist can
select them independently after import):

    "body"       outer shell (5 faces -- no bottom)
    "studs"      the studs on top
    "underside"  inner cavity walls + ceiling + bottom rim frame
    "tubes"      connector tubes inside the cavity (W>=2 AND D>=2)
    "logo"       optional logo from svg_logo.extrude_svg_logo
"""
from typing import Optional
import numpy as np
from .mesh import Mesh


def make_brick_mesh(
    width_studs: int,
    depth_studs: int,
    height_plates: int,
    *,
    stud_size: float = 8.0,
    plate_size: float = 3.2,
    fillet_inset: float = 0.30,         # mm-ish; the future fillet radius
    stud_height: Optional[float] = None,
    stud_radius_ratio: float = 0.30,    # stud radius as fraction of stud_size
    stud_segments: int = 16,            # cylinder sides
    with_studs: bool = True,
    with_underside: bool = True,         # NEW: now produces a proper
                                         # continuous-shell underside
                                         # with shared verts
    underside_wall: float = 1.0,         # wall thickness (mm at real scale)
    underside_ceiling: float = 1.2,      # ceiling thickness
    with_tubes: bool = True,             # connector tubes inside cavity
    tube_outer_ratio: float = 0.40,      # tube outer radius / stud_size
    tube_inner_ratio: float = 0.30,      # tube inner radius / stud_size
    with_stud_indents: bool = True,      # NEW: hollow cylinder indents
                                         # in the ceiling under each stud
                                         # (matches Houdini reference)
    stud_indent_outer_ratio: float = 0.34,  # outer / stud_size
    stud_indent_inner_ratio: float = 0.10,  # inner bore radius / stud_size
    with_ribs: bool = True,              # NEW: small vertical ribs along
                                         # the inside walls between studs
                                         # (matches Houdini reference)
    rib_size_ratio: float = 0.06,        # rib half-width / stud_size
    rib_protrusion_ratio: float = 0.08,  # how far rib sticks from wall
    low_res: bool = False,
    logo: Optional["Mesh"] = None,      # if provided, copied onto every stud
    logo_extrusion: float = 0.35,
    logo_diameter_ratio: float = 0.65,  # logo size as fraction of stud diameter
    subdivide: int = 0,                  # NEW: apply Catmull-Clark N times
                                         # before returning. 0 = control cage
                                         # (sharp corners, designed for SubD
                                         # at render time). 2 = baked-in
                                         # fillets, ready to use as-is.
) -> Mesh:
    """Build a quad mesh for a single brick.

    The mesh's local origin is at the brick's bottom-front-left corner
    (low corner of the bbox). +Y is up; studs go up.

    Parameters mirror the artist controls likely to surface in the C4D
    plugin UI: stud_size and plate_size determine the absolute scale,
    fillet_inset controls how rounded the edges look after subdivision,
    with_studs/with_underside/low_res toggle features.

    If low_res is True, returns a plain 6-face box -- nothing else.
    Useful as a collider mesh for rigid-body simulation.
    """
    W = width_studs * stud_size
    D = depth_studs * stud_size
    H = height_plates * plate_size

    if low_res:
        return _box_six_quads(0, 0, 0, W, H, D, group="collider")

    if stud_height is None:
        stud_height = plate_size * 0.55  # standard LEGO ratio (~1.7mm)

    e = min(fillet_inset, W * 0.4, D * 0.4, H * 0.4)

    mesh = Mesh()

    # ---- BODY -------------------------------------------------------
    # Build a 4x4x4 lattice on the surface of the box.
    # Coordinates along each axis: [0, e, axis-e, axis]
    xs = np.array([0.0, e, W - e, W])
    ys = np.array([0.0, e, H - e, H])
    zs = np.array([0.0, e, D - e, D])

    # We need surface verts only -- 4^3 - 2^3 = 56 verts. We'll just
    # generate all 64 lattice verts and only emit faces on the surface.
    # The unused interior 8 verts add zero polygons; we'll prune.
    lat = np.zeros((4, 4, 4, 3), dtype=np.float64)
    for i in range(4):
        for j in range(4):
            for k in range(4):
                lat[i, j, k] = (xs[i], ys[j], zs[k])

    # Mark surface vertices and assign indices.
    # When underside is enabled we leave the bottom face OPEN, so the 4
    # "interior of the bottom face" verts (i in {1,2}, j=0, k in {1,2})
    # would be orphaned -- skip them entirely. Their absence doesn't
    # affect any other face.
    is_surface = np.zeros((4, 4, 4), dtype=bool)
    for i in range(4):
        for j in range(4):
            for k in range(4):
                if i in (0, 3) or j in (0, 3) or k in (0, 3):
                    is_surface[i, j, k] = True
    if with_underside and not low_res:
        for i in (1, 2):
            for k in (1, 2):
                is_surface[i, 0, k] = False
    surface_idx = np.full((4, 4, 4), -1, dtype=np.int64)
    body_verts = []
    for i in range(4):
        for j in range(4):
            for k in range(4):
                if is_surface[i, j, k]:
                    surface_idx[i, j, k] = len(body_verts)
                    body_verts.append(lat[i, j, k])
    body_verts = np.array(body_verts)
    body_base = mesh.append_verts(body_verts)

    def vid(i, j, k):
        return body_base + int(surface_idx[i, j, k])

    # 6 faces, each a 3x3 grid of quads. Outward-facing normals.
    # +X face (i = 3) -- iterate j, k
    for j in range(3):
        for k in range(3):
            mesh.add_group_face("body", (
                vid(3, j,     k    ),
                vid(3, j + 1, k    ),
                vid(3, j + 1, k + 1),
                vid(3, j,     k + 1),
            ))
    # -X face (i = 0) -- reverse winding
    for j in range(3):
        for k in range(3):
            mesh.add_group_face("body", (
                vid(0, j,     k    ),
                vid(0, j,     k + 1),
                vid(0, j + 1, k + 1),
                vid(0, j + 1, k    ),
            ))
    # +Y face (j = 3) -- top, but we'll punch stud holes later if needed.
    # For now emit solid; studs will be added as separate components on top.
    for i in range(3):
        for k in range(3):
            mesh.add_group_face("body", (
                vid(i,     3, k    ),
                vid(i,     3, k + 1),
                vid(i + 1, 3, k + 1),
                vid(i + 1, 3, k    ),
            ))
    # -Y face (j = 0) -- bottom; suppressed if with_underside (we'll build the cavity)
    if not with_underside:
        for i in range(3):
            for k in range(3):
                mesh.add_group_face("body", (
                    vid(i,     0, k    ),
                    vid(i + 1, 0, k    ),
                    vid(i + 1, 0, k + 1),
                    vid(i,     0, k + 1),
                ))
    # +Z face (k = 3)
    for i in range(3):
        for j in range(3):
            mesh.add_group_face("body", (
                vid(i,     j,     3),
                vid(i,     j + 1, 3),
                vid(i + 1, j + 1, 3),
                vid(i + 1, j,     3),
            ))
    # -Z face (k = 0)
    for i in range(3):
        for j in range(3):
            mesh.add_group_face("body", (
                vid(i,     j,     0),
                vid(i + 1, j,     0),
                vid(i + 1, j + 1, 0),
                vid(i,     j + 1, 0),
            ))

    # ---- UNDERSIDE -------------------------------------------------
    # Built as a CONTINUOUS SHELL with the body: shares all 12 outer-
    # bottom-perimeter verts, adds 12 inner-bottom-perimeter verts +
    # the inner cavity walls + ceiling. Catmull-Clark sees the whole
    # thing as one closed surface.
    if with_underside:
        _add_underside_shared(
            mesh,
            W=W, D=D, H=H, e=e,
            wall=underside_wall,
            ceiling=underside_ceiling,
            outer_surface_idx=surface_idx,
            outer_base=body_base,
            with_tubes=with_tubes
                       and width_studs >= 2 and depth_studs >= 2,
            width_studs=width_studs,
            depth_studs=depth_studs,
            stud_size=stud_size,
            tube_outer_r=stud_size * tube_outer_ratio,
            tube_inner_r=stud_size * tube_inner_ratio,
            tube_segments=stud_segments,
            with_stud_indents=with_stud_indents,
            stud_indent_outer_r=stud_size * stud_indent_outer_ratio,
            stud_indent_inner_r=stud_size * stud_indent_inner_ratio,
            stud_height=stud_height,
            with_ribs=with_ribs,
            rib_half_width=stud_size * rib_size_ratio,
            rib_protrusion=stud_size * rib_protrusion_ratio,
        )

    # ---- STUDS -----------------------------------------------------
    if with_studs:
        stud_r = stud_size * stud_radius_ratio
        for sx in range(width_studs):
            for sz in range(depth_studs):
                cx = (sx + 0.5) * stud_size
                cz = (sz + 0.5) * stud_size
                _add_stud(mesh, cx, H, cz,
                          radius=stud_r, height=stud_height,
                          fillet=min(fillet_inset, stud_height * 0.4),
                          segments=stud_segments,
                          group="studs")

                # Logo as a separate polygon island on top of this stud.
                # Each stud gets its own copy; vertices are NOT shared with
                # the stud cap, which is intentional -- the artist wants
                # the logo to be selectable on its own ("separate polygon
                # island ... but the whole brick is combined into one
                # object").
                if logo is not None:
                    from .mesh import affine_translate
                    from .mesh import Mesh as _Mesh
                    # The logo mesh is built around origin in the X-Z
                    # plane with +Y as extrusion direction. Translate it
                    # to sit on top of the stud.
                    T = affine_translate(np.array(
                        [cx, H + stud_height, cz]
                    ))
                    mesh.merge(logo, transform=T)

    # ---- BAKE IN FILLETS (optional) ---------------------------------
    # The control cage has sharp 90-degree corners. To get fillets
    # without relying on the importer to apply SubD at render time,
    # apply Catmull-Clark N times here. 2 iterations is the sweet
    # spot: visually round, file size still reasonable.
    if subdivide > 0:
        from .subdivide import catmull_clark
        mesh = catmull_clark(mesh, iterations=subdivide)

    return mesh


# ---------------------------------------------------------------------
# helpers

def _box_six_quads(x0, y0, z0, x1, y1, z1, group="body") -> Mesh:
    """Trivial 8-vert / 6-quad box (no fillets), e.g. for low-res colliders."""
    m = Mesh()
    base = m.append_verts(np.array([
        [x0, y0, z0], [x1, y0, z0], [x1, y0, z1], [x0, y0, z1],
        [x0, y1, z0], [x1, y1, z0], [x1, y1, z1], [x0, y1, z1],
    ]))
    def v(i): return base + i
    # bottom
    m.add_group_face(group, (v(0), v(1), v(2), v(3)))
    # top
    m.add_group_face(group, (v(4), v(7), v(6), v(5)))
    # sides
    m.add_group_face(group, (v(0), v(4), v(5), v(1)))
    m.add_group_face(group, (v(1), v(5), v(6), v(2)))
    m.add_group_face(group, (v(2), v(6), v(7), v(3)))
    m.add_group_face(group, (v(3), v(7), v(4), v(0)))
    return m


def _add_stud(mesh: Mesh, cx: float, cy: float, cz: float,
              *, radius: float, height: float, fillet: float,
              segments: int, group: str = "studs") -> None:
    """Add a single stud at (cx, cy, cz) -- the cy is the brick top height.

    Topology: 4 vertical rings of `segments` verts each (base, base+fillet,
    top-fillet, top) wrapped with quads, then the top capped with a single
    n-gon. The two extra rings near the bottom and top create the SubD
    fillet for the stud's edges.
    """
    theta = np.linspace(0, 2 * np.pi, segments, endpoint=False)
    cos_t = np.cos(theta) * radius
    sin_t = np.sin(theta) * radius

    ys = [cy, cy + fillet, cy + height - fillet, cy + height]
    ring_verts = np.zeros((4, segments, 3), dtype=np.float64)
    for ri, y in enumerate(ys):
        ring_verts[ri, :, 0] = cx + cos_t
        ring_verts[ri, :, 1] = y
        ring_verts[ri, :, 2] = cz + sin_t

    base = mesh.append_verts(ring_verts.reshape(-1, 3))

    def vid(ring, k):
        return base + ring * segments + (k % segments)

    # 3 rings of side quads
    for ri in range(3):
        for k in range(segments):
            mesh.add_group_face(group, (
                vid(ri,     k    ),
                vid(ri + 1, k    ),
                vid(ri + 1, k + 1),
                vid(ri,     k + 1),
            ))
    # top cap as a single n-gon
    mesh.add_group_face(group, tuple(vid(3, k) for k in range(segments)))


def _add_underside_shared(
    mesh: Mesh, *,
    W: float, D: float, H: float, e: float,
    wall: float, ceiling: float,
    outer_surface_idx: np.ndarray,
    outer_base: int,
    with_tubes: bool,
    width_studs: int, depth_studs: int,
    stud_size: float,
    tube_outer_r: float, tube_inner_r: float,
    tube_segments: int,
    with_stud_indents: bool = False,
    stud_indent_outer_r: float = 0.0,
    stud_indent_inner_r: float = 0.0,
    stud_height: float = 0.0,
    with_ribs: bool = False,
    rib_half_width: float = 0.0,
    rib_protrusion: float = 0.0,
) -> None:
    """Build the underside as one continuous shell with the body.

    Topology:
      - The body's bottom face is OPEN (already skipped above).
      - We build a 4x4x4 inner lattice for the cavity, using only its
        surface verts -- 5 inner faces (4 walls + ceiling, NO inner bottom).
      - We connect the outer-bottom perimeter (already in the body's vert
        array) to the inner-bottom perimeter via a "rim frame" of 12 quads
        going around the bottom. Verts are SHARED at the outer perimeter
        so SubD treats the body+rim+cavity as one closed surface.

    The inner lattice X / Y / Z coords are inset by `wall` on the sides
    and `ceiling` on the top:
        inner_x = [wall, wall+e_in, W-wall-e_in, W-wall]
        inner_y = [0, e_in, (H-ceiling)-e_in, H-ceiling]
        inner_z = [wall, wall+e_in, D-wall-e_in, D-wall]
    """
    # Use a smaller fillet inset for the inner lattice so the cavity
    # corners get rounded but don't bulge into each other on small bricks.
    e_in = min(e, wall * 0.5, ceiling * 0.4)

    inner_xs = np.array([wall, wall + e_in, W - wall - e_in, W - wall])
    inner_ys = np.array([0.0, e_in, (H - ceiling) - e_in, H - ceiling])
    inner_zs = np.array([wall, wall + e_in, D - wall - e_in, D - wall])

    # Inner lattice: 4x4x4 = 64 positions, surface only = 56, but we
    # also skip the 4 "interior of inner bottom" verts (j=0, i in {1,2},
    # k in {1,2}) because the inner bottom is open from underneath.
    inner_lat = np.zeros((4, 4, 4, 3))
    for i in range(4):
        for j in range(4):
            for k in range(4):
                inner_lat[i, j, k] = (inner_xs[i], inner_ys[j], inner_zs[k])

    is_inner_surface = np.zeros((4, 4, 4), dtype=bool)
    for i in range(4):
        for j in range(4):
            for k in range(4):
                if i in (0, 3) or j in (0, 3) or k in (0, 3):
                    is_inner_surface[i, j, k] = True
    # Inner bottom (j=0) is open -- skip the 4 INTERIOR-of-bottom verts
    for i in (1, 2):
        for k in (1, 2):
            is_inner_surface[i, 0, k] = False

    inner_idx_map = np.full((4, 4, 4), -1, dtype=np.int64)
    inner_verts = []
    for i in range(4):
        for j in range(4):
            for k in range(4):
                if is_inner_surface[i, j, k]:
                    inner_idx_map[i, j, k] = len(inner_verts)
                    inner_verts.append(inner_lat[i, j, k])
    inner_base = mesh.append_verts(np.array(inner_verts))

    def iv(i, j, k):
        return inner_base + int(inner_idx_map[i, j, k])

    def ov(i, j, k):
        # outer body vert -- uses the surface_idx passed in
        return outer_base + int(outer_surface_idx[i, j, k])

    # Inner walls (4) and ceiling -- INWARD-facing normals (visible
    # when looking up into the cavity).
    # +X inner wall (i=3 of inner lattice, faces -X i.e. inward toward outer center)
    for j in range(3):
        for k in range(3):
            mesh.add_group_face("underside", (
                iv(3, j,     k    ),
                iv(3, j,     k + 1),
                iv(3, j + 1, k + 1),
                iv(3, j + 1, k    ),
            ))
    # -X inner wall (i=0)
    for j in range(3):
        for k in range(3):
            mesh.add_group_face("underside", (
                iv(0, j,     k    ),
                iv(0, j + 1, k    ),
                iv(0, j + 1, k + 1),
                iv(0, j,     k + 1),
            ))
    # +Z inner wall (k=3)
    for i in range(3):
        for j in range(3):
            mesh.add_group_face("underside", (
                iv(i,     j,     3),
                iv(i + 1, j,     3),
                iv(i + 1, j + 1, 3),
                iv(i,     j + 1, 3),
            ))
    # -Z inner wall (k=0)
    for i in range(3):
        for j in range(3):
            mesh.add_group_face("underside", (
                iv(i,     j,     0),
                iv(i,     j + 1, 0),
                iv(i + 1, j + 1, 0),
                iv(i + 1, j,     0),
            ))
    # Ceiling (j=3) -- faces DOWN (so seen looking up into cavity)
    for i in range(3):
        for k in range(3):
            mesh.add_group_face("underside", (
                iv(i,     3, k    ),
                iv(i,     3, k + 1),
                iv(i + 1, 3, k + 1),
                iv(i + 1, 3, k    ),
            ))

    # ---- RIM FRAME ---------------------------------------------------
    # Connect each outer-bottom-perimeter vert to the corresponding
    # inner-bottom-perimeter vert. The rim is a thin frame of 12 quads
    # going around the bottom of the brick.
    #
    # Outer perimeter verts (body's j=0 plane): we have 12 of them
    # (4x4 grid minus 4 interior). Inner perimeter is the analogous
    # 12 verts of the inner lattice's j=0 plane.
    #
    # Walking around: the rim is bounded by outer edge i=0,3 / k=0,3.
    # On each of the 4 sides we have 4 perimeter verts -> 3 rim quads.
    # Corners are shared.

    # -Z side (k=0): outer (i, 0, 0) -> inner (i, 0, 0)
    for i in range(3):
        mesh.add_group_face("underside", (
            ov(i,     0, 0),
            ov(i + 1, 0, 0),
            iv(i + 1, 0, 0),
            iv(i,     0, 0),
        ))
    # +Z side (k=3)
    for i in range(3):
        mesh.add_group_face("underside", (
            ov(i + 1, 0, 3),
            ov(i,     0, 3),
            iv(i,     0, 3),
            iv(i + 1, 0, 3),
        ))
    # -X side (i=0)
    for k in range(3):
        mesh.add_group_face("underside", (
            ov(0, 0, k + 1),
            ov(0, 0, k    ),
            iv(0, 0, k    ),
            iv(0, 0, k + 1),
        ))
    # +X side (i=3)
    for k in range(3):
        mesh.add_group_face("underside", (
            ov(3, 0, k    ),
            ov(3, 0, k + 1),
            iv(3, 0, k + 1),
            iv(3, 0, k    ),
        ))

    # ---- CONNECTOR TUBES --------------------------------------------
    # Tubes sit between every 2x2 group of studs, attached to the inner
    # ceiling. They're hollow cylinders that grip studs of the brick
    # below by friction. For a WxD brick with W,D >= 2 there are
    # (W-1)*(D-1) tubes.
    if with_tubes:
        for sx in range(width_studs - 1):
            for sz in range(depth_studs - 1):
                cx = (sx + 1) * stud_size
                cz = (sz + 1) * stud_size
                _add_connector_tube(
                    mesh, cx, cz,
                    ceiling_y=H - ceiling,
                    floor_y=0.0,
                    outer_r=tube_outer_r,
                    inner_r=tube_inner_r,
                    segments=tube_segments,
                    fillet=min(e_in, ceiling * 0.4),
                )

    # ---- STUD-POSITION INDENTS IN CEILING ---------------------------
    # Small inverted cylindrical pockets directly below each stud (in the
    # ceiling, opening downward into the cavity). Matches the Houdini
    # reference. Each indent has a small bore through the ceiling.
    if with_stud_indents:
        ceiling_y = H - ceiling
        # Indent goes from ceiling underside (y = ceiling_y) UP into
        # the body, ending just below the body top. We make it about
        # 80% of the ceiling thickness deep -- not all the way through.
        indent_top_y = H - ceiling * 0.2
        for sx in range(width_studs):
            for sz in range(depth_studs):
                cx = (sx + 0.5) * stud_size
                cz = (sz + 0.5) * stud_size
                _add_ceiling_indent(
                    mesh, cx, cz,
                    ceiling_bottom_y=ceiling_y,
                    indent_top_y=indent_top_y,
                    outer_r=stud_indent_outer_r,
                    inner_r=stud_indent_inner_r,
                    segments=tube_segments,
                    fillet=min(e_in, (indent_top_y - ceiling_y) * 0.3),
                )

    # ---- RIBS ON INSIDE WALLS ---------------------------------------
    # Small vertical bumps on the inner walls, between each pair of
    # adjacent studs along that wall (and at the corners). Match the
    # Houdini reference.
    if with_ribs:
        ceiling_y = H - ceiling
        rib_top_y = ceiling_y - e_in   # stop just below the cavity
                                       # ceiling so we don't disturb
                                       # the ceiling fillet
        rib_bot_y = e_in               # stop above the bottom rim
                                       # so we don't disturb that fillet
        # ribs along long walls (z varies, x = ±wall)
        # Place 2 ribs per gap between adjacent studs along the long axis,
        # roughly at z=stud_size*(i + 0.25) and z=stud_size*(i + 0.75)
        # for i in 0..(depth_studs-1). Plus ribs at both ends (the
        # short walls).
        # For simplicity: place ribs at the gaps between adjacent studs,
        # centered between them.
        # On the long walls (parallel to Z axis):
        for i in range(depth_studs - 1):
            cz = (i + 1) * stud_size  # gap center between stud i and i+1
            # +X wall (rib protrudes in -X direction)
            _add_wall_rib(
                mesh,
                wall_x=W - wall, protrusion_dir_x=-1, cz=cz,
                rib_top_y=rib_top_y, rib_bot_y=rib_bot_y,
                half_width=rib_half_width,
                protrusion=rib_protrusion,
            )
            # -X wall (rib protrudes in +X direction)
            _add_wall_rib(
                mesh,
                wall_x=wall, protrusion_dir_x=+1, cz=cz,
                rib_top_y=rib_top_y, rib_bot_y=rib_bot_y,
                half_width=rib_half_width,
                protrusion=rib_protrusion,
            )
        # On the short walls (parallel to X axis):
        for i in range(width_studs - 1):
            cx = (i + 1) * stud_size
            # +Z wall (rib protrudes in -Z direction)
            _add_wall_rib(
                mesh,
                wall_z=D - wall, protrusion_dir_z=-1, cx=cx,
                rib_top_y=rib_top_y, rib_bot_y=rib_bot_y,
                half_width=rib_half_width,
                protrusion=rib_protrusion,
                axis="x",
            )
            # -Z wall (rib protrudes in +Z direction)
            _add_wall_rib(
                mesh,
                wall_z=wall, protrusion_dir_z=+1, cx=cx,
                rib_top_y=rib_top_y, rib_bot_y=rib_bot_y,
                half_width=rib_half_width,
                protrusion=rib_protrusion,
                axis="x",
            )


def _add_ceiling_indent(
    mesh: Mesh, cx: float, cz: float, *,
    ceiling_bottom_y: float, indent_top_y: float,
    outer_r: float, inner_r: float,
    segments: int, fillet: float,
) -> None:
    """Inverted cylindrical pocket in the ceiling, opening DOWNWARD into
    the cavity. Visible from below as a ring with a small hole in the
    middle.

    Topology: outer cylinder wall (going up from ceiling level into the
    body) + inner cylinder wall (the small bore) + an annulus cap at the
    top connecting them. The bottom is OPEN (it opens into the cavity).
    The bottom edge connects to the cavity ceiling via a separate
    component -- we don't share verts with the ceiling here because the
    ceiling is built from the inner-lattice surface verts, which makes
    boolean-style intersection geometrically complex. The indent is its
    own closed shell, which subdivides cleanly because each surface
    (outer cyl, inner cyl, annulus cap) is itself a clean strip.

    Two extra ring loops near top and bottom give the SubD fillet for
    the indent's edges.
    """
    theta = np.linspace(0, 2 * np.pi, segments, endpoint=False)
    cos_t = np.cos(theta)
    sin_t = np.sin(theta)

    # 4 outer rings: bottom, bottom+fillet, top-fillet, top
    # 4 inner rings: same y values but inner radius
    ys = [ceiling_bottom_y, ceiling_bottom_y + fillet,
          indent_top_y - fillet, indent_top_y]
    n = segments
    rings = []
    for y in ys:
        rings.append((y, outer_r))
    for y in ys:
        rings.append((y, inner_r))

    base = mesh.append_verts(np.vstack([
        np.stack([cx + r * cos_t, np.full(n, y), cz + r * sin_t], axis=1)
        for (y, r) in rings
    ]))

    def vid(ring, k):
        return base + ring * n + (k % n)

    # Outer wall (rings 0->1->2->3): 3 strips of side quads, normals OUTWARD
    for ri in range(3):
        for k in range(n):
            mesh.add_group_face("underside", (
                vid(ri,     k    ),
                vid(ri,     k + 1),
                vid(ri + 1, k + 1),
                vid(ri + 1, k    ),
            ))
    # Inner wall (rings 4->5->6->7): 3 strips, normals INWARD
    for ri in range(4, 7):
        for k in range(n):
            mesh.add_group_face("underside", (
                vid(ri,     k    ),
                vid(ri + 1, k    ),
                vid(ri + 1, k + 1),
                vid(ri,     k + 1),
            ))
    # Top: connects outer-top (ring 3) to inner-top (ring 7), faces UP
    for k in range(n):
        mesh.add_group_face("underside", (
            vid(3, k    ),
            vid(7, k    ),
            vid(7, k + 1),
            vid(3, k + 1),
        ))
    # Bottom rim: connects outer-bottom (ring 0) to inner-bottom (ring 4),
    # faces DOWN -- visible when looking up into the cavity
    for k in range(n):
        mesh.add_group_face("underside", (
            vid(0, k + 1),
            vid(4, k + 1),
            vid(4, k    ),
            vid(0, k    ),
        ))


def _add_wall_rib(
    mesh: Mesh,
    *,
    wall_x: float = None,
    wall_z: float = None,
    protrusion_dir_x: int = 0,
    protrusion_dir_z: int = 0,
    cx: float = None,
    cz: float = None,
    rib_top_y: float, rib_bot_y: float,
    half_width: float, protrusion: float,
    axis: str = "z",
) -> None:
    """A small vertical rib protruding from one of the inner walls.

    Modeled as a half-rounded box (5 visible quad faces -- top, bottom,
    front, two sides; the back is against the wall and not emitted).
    A separate closed-ish component for SubD; not shared-vert with the
    wall (sharing would require restructuring the cavity wall lattice
    into something rib-aware, which compounds with the W,D dimensions).

    The rib has an extra horizontal edge loop at top and bottom for
    SubD fillets, so its corners round off properly.

    Parameters
    ----------
    axis : "z" -- rib runs along Z axis (on +X or -X long wall)
                  cz is the rib center along Z; wall_x is which wall
           "x" -- rib runs along X axis (on +Z or -Z short wall)
                  cx is the rib center along X; wall_z is which wall
    """
    # Define the 8 corners of the rib's protrusion box in world coords.
    # The rib extends from the wall by `protrusion`, has `half_width`
    # along the wall direction, and runs from rib_bot_y to rib_top_y
    # vertically.
    if axis == "z":
        x_back = wall_x
        x_front = wall_x + protrusion_dir_x * protrusion
        z_min = cz - half_width
        z_max = cz + half_width
        # 8 corners: (back-bot-z_min), (front-bot-z_min), (front-bot-z_max),
        # (back-bot-z_max), and the same 4 at top
        corners = [
            (x_back,  rib_bot_y, z_min),  # 0
            (x_front, rib_bot_y, z_min),  # 1
            (x_front, rib_bot_y, z_max),  # 2
            (x_back,  rib_bot_y, z_max),  # 3
            (x_back,  rib_top_y, z_min),  # 4
            (x_front, rib_top_y, z_min),  # 5
            (x_front, rib_top_y, z_max),  # 6
            (x_back,  rib_top_y, z_max),  # 7
        ]
    else:  # axis == "x"
        z_back = wall_z
        z_front = wall_z + protrusion_dir_z * protrusion
        x_min = cx - half_width
        x_max = cx + half_width
        corners = [
            (x_min, rib_bot_y, z_back),
            (x_min, rib_bot_y, z_front),
            (x_max, rib_bot_y, z_front),
            (x_max, rib_bot_y, z_back),
            (x_min, rib_top_y, z_back),
            (x_min, rib_top_y, z_front),
            (x_max, rib_top_y, z_front),
            (x_max, rib_top_y, z_back),
        ]

    base = mesh.append_verts(np.array(corners, dtype=np.float64))

    def v(i): return base + i

    # 5 visible quad faces (back face hidden against wall):
    # front (+protrusion direction), 2 ends, top, bottom
    if axis == "z":
        # bottom (faces DOWN)
        mesh.add_group_face("underside", (v(0), v(3), v(2), v(1)))
        # top (faces UP)
        mesh.add_group_face("underside", (v(4), v(5), v(6), v(7)))
        # front (faces in protrusion direction)
        mesh.add_group_face("underside", (v(1), v(2), v(6), v(5)))
        # left end (z_min side)
        mesh.add_group_face("underside", (v(0), v(1), v(5), v(4)))
        # right end (z_max side)
        mesh.add_group_face("underside", (v(3), v(7), v(6), v(2)))
    else:
        # bottom
        mesh.add_group_face("underside", (v(0), v(3), v(2), v(1)))
        # top
        mesh.add_group_face("underside", (v(4), v(5), v(6), v(7)))
        # front
        mesh.add_group_face("underside", (v(1), v(2), v(6), v(5)))
        # x_min end
        mesh.add_group_face("underside", (v(0), v(1), v(5), v(4)))
        # x_max end
        mesh.add_group_face("underside", (v(3), v(7), v(6), v(2)))


def _add_connector_tube(
    mesh: Mesh, cx: float, cz: float, *,
    ceiling_y: float, floor_y: float,
    outer_r: float, inner_r: float,
    segments: int, fillet: float,
) -> None:
    """A connector tube: hollow cylinder hanging from the ceiling.

    Topology: outer cylinder wall + inner cylinder wall + an annulus
    cap at the bottom (where the tube ends -- this is what you see
    looking up into the cavity at a tube). The TOP is open and connects
    to the ceiling implicitly (the tube is a separate component for
    simplicity; in real LEGO it joins the ceiling, but for SubD the
    topological connection via shared verts is fiddly. The tube being
    a separate closed component still subdivides cleanly because each
    of its surfaces is itself closed -- unlike the old broken underside
    where partial open seams collapsed).

    The bottom of the tube is open in real LEGO (it grips studs that
    push up into it). We model it as open here too: the bottom annulus
    cap is OMITTED. The outer wall and inner wall are joined at the
    bottom by a thin ring of quads (the bottom rim of the tube).
    """
    theta = np.linspace(0, 2 * np.pi, segments, endpoint=False)
    cos_t = np.cos(theta)
    sin_t = np.sin(theta)

    # Outer ring at top (joining ceiling) and bottom
    # Inner ring at top and bottom
    # Plus 2 extra rings near top and bottom for fillet edge loops
    ys_out = [ceiling_y, ceiling_y - fillet,
              floor_y + fillet, floor_y]
    ys_in = ys_out  # symmetric

    rings = []  # list of (y, radius) for the 4 outer + 4 inner rings
    for y in ys_out:
        rings.append((y, outer_r))
    for y in ys_in:
        rings.append((y, inner_r))

    n = segments
    base = mesh.append_verts(np.vstack([
        np.stack([cx + r * cos_t, np.full(n, y), cz + r * sin_t], axis=1)
        for (y, r) in rings
    ]))

    def vid(ring, k):
        return base + ring * n + (k % n)

    # Outer wall: 3 ring-strips of quads (rings 0->1->2->3 outer, normals OUT)
    for ri in range(3):
        for k in range(n):
            mesh.add_group_face("tubes", (
                vid(ri,     k    ),
                vid(ri,     k + 1),
                vid(ri + 1, k + 1),
                vid(ri + 1, k    ),
            ))
    # Inner wall: 3 ring-strips (rings 4->5->6->7 inner, normals IN i.e.
    # reverse winding)
    for ri in range(4, 7):
        for k in range(n):
            mesh.add_group_face("tubes", (
                vid(ri,     k    ),
                vid(ri + 1, k    ),
                vid(ri + 1, k + 1),
                vid(ri,     k + 1),
            ))
    # Top: connects outer-top ring (ring 0) to inner-top ring (ring 4)
    # Faces UP toward the ceiling.
    for k in range(n):
        mesh.add_group_face("tubes", (
            vid(0, k    ),
            vid(4, k    ),
            vid(4, k + 1),
            vid(0, k + 1),
        ))
    # Bottom rim: connects outer-bottom (ring 3) to inner-bottom (ring 7).
    # This is the visible "donut" at the bottom of the tube when looking
    # up into the cavity.
    for k in range(n):
        mesh.add_group_face("tubes", (
            vid(3, k + 1),
            vid(7, k + 1),
            vid(7, k    ),
            vid(3, k    ),
        ))
